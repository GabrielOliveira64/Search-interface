{
  "name": "home",
  "version": "0.5.0",
  "description": "Página inicial personalizada com RSS, atalhos e busca",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.home.app",
    "productName": "Home",
    "copyright": "Copyright © 2025",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "panel.html",
      "index.html",
      "app.js",
      "style.css",
      "version.json",
      "node_modules/**/*", 
      "icon.png",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "db.json",
        "to": "db.json"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Home",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "directories": {
      "output": "dist"
    }
  }
}